# Mantle Network Testnet Configuration
# 1. Enter your MetaMask account's private key (without 0x prefix) to sign transactions
PRIVATE_KEY="YOUR_METAMASK_PRIVATE_KEY"

# 2. Enter the deployed contract address on Mantle Sepolia Testnet
MANTLE_CONTRACT_ADDRESS="0x..."

# 3. Mantle Explorer API Key for contract verification (optional)
MANTLE_EXPLORER_API_KEY="YOUR_EXPLORER_API_KEY"
